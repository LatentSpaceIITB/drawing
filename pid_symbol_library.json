{
  "schema_version": "2",
  "standard": "ISO 10628-2 / ISO 14617 + ISA 5.1",
  "coordinate_system": "top_left_origin_normalized",
  "note": "All coords in [0,1]. Scaling: x_actual=x_norm*w, y_actual=y_norm*h, r_actual=r_norm*min(w,h). stroke_width is absolute (mm). Circle elements with bisect:true emit an additional chord line at cy.",
  "resolution_rules": [
    {
      "match": {
        "ntype": "valve:isolation",
        "semantics.fail_position": "closed"
      },
      "symbol": "gate_valve_fc"
    },
    {
      "match": {
        "ntype": "valve:isolation",
        "semantics.fail_position": "open"
      },
      "symbol": "gate_valve_fo"
    },
    {
      "match": {
        "ntype": "valve:isolation"
      },
      "symbol": "gate_valve"
    },
    {
      "match": {
        "ntype": "valve:control"
      },
      "symbol": "control_valve"
    },
    {
      "match": {
        "ntype": "valve:drain"
      },
      "symbol": "drain_valve"
    },
    {
      "match": {
        "ntype": "instrument:flow_meter"
      },
      "symbol": "flow_element"
    },
    {
      "match": {
        "ntype": "actuator:pneumatic"
      },
      "symbol": "diaphragm_actuator"
    },
    {
      "match": {
        "ntype": "instrument:controller"
      },
      "symbol": "controller_bubble"
    },
    {
      "match": {
        "ntype": "instrument:transmitter"
      },
      "symbol": "transmitter_bubble"
    },
    {
      "match": {
        "ntype": "instrument:pressure"
      },
      "symbol": "pressure_indicator"
    },
    {
      "match": {
        "ntype": "instrument:temperature"
      },
      "symbol": "temperature_indicator"
    },
    {
      "match": {
        "ntype": "instrument:level"
      },
      "symbol": "level_indicator"
    },
    {
      "match": {
        "ntype": "tank"
      },
      "symbol": "tank_horizontal"
    },
    {
      "match": {
        "ntype": "pump"
      },
      "symbol": "pump_centrifugal"
    },
    {
      "match": {
        "ntype": "inlet_outlet"
      },
      "symbol": "inlet_outlet_connector"
    },
    {
      "match": {
        "ntype": "motor:driver"
      },
      "symbol": "motor_driver"
    },
    {
      "match": {
        "ntype": "pipe_segment"
      },
      "symbol": "pipe_straight"
    },
    {
      "match": {
        "ntype": "equipment_block"
      },
      "symbol": "vessel"
    }
  ],
  "symbols": {
